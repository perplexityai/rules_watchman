config_setting(
    name = "linux",
    constraint_values = ["@platforms//os:linux"],
)

config_setting(
    name = "macos",
    constraint_values = ["@platforms//os:macos"],
)

cc_library(
    name = "config_h",
    hdrs = select({
        ":linux": ["watchman/config/linux/config.h"],
        ":macos": ["watchman/config/macos/config.h"],
    }),
    include_prefix = "watchman",
    strip_include_prefix = select({
        ":linux": "watchman/config/linux",
        ":macos": "watchman/config/macos",
    }),
)

cc_binary(
    name = "watchman",
    srcs = WATCHMAN_SRCS + glob(
        ["watchman/**/*.h"],
        exclude = ["watchman/thirdparty/deelevate_binding/**"],
    ),
    copts = [
        "-Wall",
        "-Wextra",
        "-DGLOG_NO_ABBREVIATED_SEVERITIES",
        "-I.",
    ] + select({
        ":linux": ["-pthread"],
        "//conditions:default": [],
    }),
    includes = ["."],
    linkopts = select({
        ":linux": ["-pthread"],
        ":macos": [
            "-framework",
            "CoreServices",
        ],
    }),
    linkstatic = True,
    deps = [
        ":config_h",
        "@edencommon//:edencommon",
        "@fb303//:fb303",
        "@fmt",
        "@folly//folly:exception",
        "@folly//folly:exception_string",
        "@folly//folly:exception_wrapper",
