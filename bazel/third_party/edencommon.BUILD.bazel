load("@rules_cc//cc:defs.bzl", "cc_library")

package(default_visibility = ["//visibility:public"])

genrule(
    name = "eden_config",
    srcs = ["CMake/eden-config.h.in"],
    outs = ["eden/common/eden-config.h"],
    cmd = "cp $< $@",
)

cc_library(
    name = "edencommon_utils",
    srcs = [
        "eden/common/utils/FaultInjector.cpp",
        "eden/common/utils/FileDescriptor.cpp",
        "eden/common/utils/PathFuncs.cpp",
        "eden/common/utils/Pipe.cpp",
        "eden/common/utils/ProcessInfo.cpp",
        "eden/common/utils/ProcessInfoCache.cpp",
        "eden/common/utils/SpawnedProcess.cpp",
        "eden/common/utils/String.cpp",
        "eden/common/utils/StringConv.cpp",
        "eden/common/utils/SysctlUtil.cpp",
        "eden/common/utils/UserInfo.cpp",
        "eden/common/utils/Utf8.cpp",
    ] + select({
        "@platforms//os:windows": [
            "eden/common/utils/FileUtils.cpp",
            "eden/common/utils/windows/PlatformWindowsUnixSock.cpp",
            "eden/common/utils/windows/WinError.cpp",
            "eden/common/utils/windows/WinUtil.cpp",
        ],
        "//conditions:default": [],
    }),
    hdrs = glob(
        ["eden/common/utils/**/*.h"],
        exclude = ["eden/common/utils/test/**"],
    ),
    includes = ["."],
    linkopts = select({
        "@platforms//os:windows": [
            "-ldbghelp",
            "-lrpcrt4",
            "-luserenv",
        ],
        "//conditions:default": [],
    }),
    deps = [
        "@boost.filesystem//:boost.filesystem",
        "@boost.regex//:boost.regex",
        "@boost.utility//:boost.utility",
        "@fmt",
        "@folly//folly:cancellation_token",
        "@folly//folly:conv",
        "@folly//folly:exception",
        "@folly//folly:file",
        "@folly//folly:file_util",
        "@folly//folly:format",
        "@folly//folly:map_util",
        "@folly//folly:overload",
        "@folly//folly:portability",
        "@folly//folly:scope_guard",
        "@folly//folly:stop_watch",
        "@folly//folly:string",
        "@folly//folly:synchronized",
        "@folly//folly:try",
        "@folly//folly:unicode",
        "@folly//folly:unit",
        "@folly//folly/container:evicting_cache_map",
        "@folly//folly/container:f14_hash",
        "@folly//folly/coro:sleep",
        "@folly//folly/coro:task",
        "@folly//folly/coro/safe:now_task",
        "@folly//folly/futures:core",
        "@folly//folly/futures:shared_promise",
        "@folly//folly/logging",
        "@folly//folly/portability:fcntl",
        "@folly//folly/portability:sockets",
        "@folly//folly/portability:sys_stat",
        "@folly//folly/portability:sys_time",
        "@folly//folly/portability:sys_types",
        "@folly//folly/portability:sys_uio",
        "@folly//folly/portability:unistd",
        "@folly//folly/system:shell",
        "@folly//folly/system:thread_name",
        "@googletest//:gtest_prod",
    ],
)

cc_library(
    name = "edencommon_telemetry",
    srcs = [
        "eden/common/telemetry/DynamicEvent.cpp",
        "eden/common/telemetry/ScubaStructuredLogger.cpp",
        "eden/common/telemetry/SessionId.cpp",
        "eden/common/telemetry/SessionInfo.cpp",
        "eden/common/telemetry/StatsGroup.cpp",
        "eden/common/telemetry/StructuredLogger.cpp",
        "eden/common/telemetry/SubprocessScribeLogger.cpp",
    ],
    hdrs = glob(
        ["eden/common/telemetry/**/*.h"],
        exclude = ["eden/common/telemetry/test/**"],
    ) + [":eden_config"],
    includes = ["."],
    deps = [
        ":edencommon_utils",
        "@fb303//:fb303",
        "@folly//folly:conv",
        "@folly//folly:exception",
        "@folly//folly:json",
        "@folly//folly:portability",
        "@folly//folly:string",
        "@folly//folly:synchronized",
        "@folly//folly:unit",
        "@folly//folly/logging",
        "@folly//folly/portability:unistd",
        "@folly//folly/system:thread_name",
    ],
)

cc_library(
    name = "edencommon",
    deps = [
        ":edencommon_telemetry",
        ":edencommon_utils",
    ],
)
